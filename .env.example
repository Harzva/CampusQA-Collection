# Copy this file to .env before running docker compose.

MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=rag

REDIS_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=rag-bucket

MILVUS_COLLECTION_NAME=rag_collection
MILVUS_EMBEDDING_DIMENSION=1536

BACKEND_PORT=8080
FRONTEND_PORT=3000

# Required for real model responses.
OPENAI_API_KEY=replace-me
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Bot gateway is disabled by default. Enable only after setting verifier secrets.
BOT_ENABLED=false
BOT_DEFAULT_MODE=agent
BOT_SIGNING_SECRET=change-me-long-random-secret
BOT_TIMESTAMP_TOLERANCE_SECONDS=300
BOT_FEISHU_ENABLED=false
BOT_FEISHU_VERIFICATION_TOKEN=change-me
BOT_FEISHU_SIGNING_SECRET=change-me
BOT_FEISHU_ALLOWED_MODES=rag,wiki,agent,gbrain
BOT_DINGTALK_ENABLED=false
BOT_DINGTALK_TOKEN=change-me
BOT_DINGTALK_SIGNING_SECRET=change-me
BOT_DINGTALK_ALLOWED_MODES=rag,wiki,agent,gbrain
BOT_WECHAT_ENABLED=false
BOT_WECHAT_TOKEN=change-me
BOT_WECHAT_SIGNING_SECRET=change-me
BOT_WECHAT_ALLOWED_MODES=rag,wiki,agent,gbrain
